# Stage 1: Build
FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json ./

RUN yarn install --immutable

WORKDIR /app

COPY . .

RUN yarn build

# Stage 2: Serve
FROM nginx:stable-alpine

COPY --from=builder /app/build /usr/share/nginx/html

COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]