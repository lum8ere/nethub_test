{
  "git.ignoreLimitWarning": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "go.testEnvFile": "${workspaceFolder}/envs/local.env",
  "go.testEnvVars": {
    "GO_ENV": "test"
  },
  "[go]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go"
  },
  "go.testFlags": ["-v", "-timeout=10m"], // использовать "-race" когда нужно. нужно таймаут увеличить т.к. есть долгий тест - где каждая мета селектится
  "go.useLanguageServer": true,
  "go.autocompleteUnimportedPackages": true,
  "go.lintOnSave": "workspace",
  "go.formatTool": "gofmt",
  "go.useCodeSnippetsOnFunctionSuggest": true,
  "go.vetOnSave": "workspace",
  "go.coverageOptions": "showUncoveredCodeOnly",

  // Автопочинка ESLint и сортировка импортов при сохранении
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },

  // Гарантируем Prettier для нужных языков
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // Чтобы ESLint срабатывал оперативно
  "eslint.run": "onType",
  "go.toolsEnvVars": {}
}
